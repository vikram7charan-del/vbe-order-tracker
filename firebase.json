{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    },
    {
      "source": "kharcha-functions",
      "codebase": "kharcha"
    }
  ],
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "firestore.indexes.json",
      "storage.rules",
      ".gitignore",
      "CLAUDE.md",
      "README.md",
      "*.md",
      "**/node_modules/**",
      ".firebase/**",
      ".git/**",
      "**/.git/**",
      "functions/**",
      ".github/**",
      "vbe-admin-setup.html",
      "kharcha-functions/**"
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
