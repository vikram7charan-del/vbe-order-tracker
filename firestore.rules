rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Legacy fallback — vbe-admin-setup.html कभी vbe_admins doc नहीं बना पाया
    // था क्योंकि write हमेशा false थी (lockout bug). यह fallback तब तक रखो जब तक
    // सारे 7 UIDs के लिए vbe_admins/{uid} documents Firebase Console (Admin SDK,
    // rules से बाहर) से manually बना न दिए जाएं.
    function isLegacyAdmin() {
      return request.auth != null
          && (request.auth.uid == "FqJeXbb3YJfSER09jtXLosCSpVy2"
           || request.auth.uid == "tjkS5tg2vMflpndGHSQRjFYgRv03"
           || request.auth.uid == "0CXFV9vDMSW7LBi0mLS9bW480mh1"
           || request.auth.uid == "CrWrobyeWHY1ZLrLwKcncW0U9K03"
           || request.auth.uid == "gdn0jahlzGOuWKaOyxsTht07mus2"
           || request.auth.uid == "pFslWWEvLiRjr7YFq51TqwfOpFp2"
           || request.auth.uid == "xY7dwh799LZrRIY7dK2CHVc5H262");
    }

    // ── Admin check — vbe_admins collection से verify होता है ──
    // SETUP: vbe-admin-setup.html चलाकर पहले vbe_admins documents बनाओ
    // फिर यह rules deploy करो: firebase deploy --only firestore:rules
    function isAdmin() {
      return request.auth != null
        && (isLegacyAdmin()
            || exists(/databases/$(database)/documents/vbe_admins/$(request.auth.uid)));
    }

    // vbe_admins — admins read कर सकते हैं, अपना ही doc बना सकते हैं (bootstrap के लिए)
    match /vbe_admins/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin() && request.auth.uid == uid;
    }

    // ── खर्चा ट्रैकर roles ──
    // Staff = vbe_users/{uid} doc जिसमें role == 'staff' हो (dashboard से बनता है)
    function isStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/vbe_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/vbe_users/$(request.auth.uid)).data.role == 'staff';
    }
    function isAdminOrStaff() { return isAdmin() || isStaff(); }

    // vbe_users — हर user अपना doc पढ़ सकता है (login role check), admin सब कुछ
    match /vbe_users/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow read, write, delete: if isAdmin();
    }

    // Expense data की shape सही हो — गलत type का data कभी save न हो
    function validExpense(d) {
      return d.total is number && d.total >= 0
        && d.items is list
        && d.firm is string
        && d.date is string
        && d.staffUid is string;
    }

    // vbe_expenses — admin: सब; staff: बनाना (अपने नाम से) + अपनी pending entries update + पढ़ना (autocomplete के लिए)
    match /vbe_expenses/{id} {
      allow read: if isAdminOrStaff();
      allow create: if validExpense(request.resource.data)
        && (isAdmin() || (isStaff() && request.resource.data.staffUid == request.auth.uid));
      allow update: if validExpense(request.resource.data)
        && (isAdmin() || (isStaff() && resource.data.staffUid == request.auth.uid));
      allow delete: if isAdmin();
    }

    // AI proxy URL — deploy workflow इसे लिखता है (Admin SDK, rules bypass);
    // app में staff+admin दोनों को पढ़ना है ताकि AI auto-entry सबके लिए चले
    match /vbe_settings/kharcha_ai {
      allow get: if isAdminOrStaff();
      allow write: if isAdmin();
    }

    // vbe_pricebook — auto-populate हर expense से; merge सिर्फ admin
    match /vbe_pricebook/{id} {
      allow read, create: if isAdminOrStaff();
      allow update, delete: if isAdmin();
    }

    // vbe_payment_accounts — editable master (admin), staff सिर्फ पढ़े
    match /vbe_payment_accounts/{id} {
      allow read: if isAdminOrStaff();
      allow write, delete: if isAdmin();
    }

    // vbe_kharcha_units — army units master (admin only)
    match /vbe_kharcha_units/{id} {
      allow read, write, delete: if isAdmin();
    }

    // unit_receivables — admin only (पैसा डूबने से बचाने वाला module)
    match /unit_receivables/{id} {
      allow read, write, delete: if isAdmin();
    }

    // मारवाड़ रसोई डेली मैनेजमेंट — admin only
    match /mr_daily/{id} {
      allow read, write, delete: if isAdmin();
    }
    match /mr_udhari/{id} {
      allow read, write, delete: if isAdmin();
    }
    match /mr_staff_ledger/{id} {
      allow read, write, delete: if isAdmin();
    }

    // notification_queue — n8n WhatsApp reminders (n8n service-account/REST से पढ़ता है)
    match /notification_queue/{id} {
      allow read, create, update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // _audit_logs — delete/edit का record; कोई edit/delete नहीं
    match /_audit_logs/{id} {
      allow create: if isAdminOrStaff();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /vbe_orders/{orderId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /vbe_tasks/{taskId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_staff/{staffId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_rewards/{rewardId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_parties/{partyId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_projects/{projectId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_challans/{challanId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_contacts/{contactId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_attendance/{docId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_settings/{docId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_bank_accounts/{docId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_bank_entries/{docId} {
      allow read, write, delete: if isAdmin();
    }

    match /fvhq_assigns/{docId} {
      allow read, write, delete: if isAdmin();
    }

    match /fvhq_summaries/{staffId} {
      allow read, write, delete: if isAdmin();
    }

    match /fvhq_contacts/{unitId} {
      allow read, write, delete: if isAdmin();
    }

    match /fvhq_custom_units/{unitId} {
      allow read, write, delete: if isAdmin();
    }

    match /mr_bills/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /mr_cash/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /mr_staff/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /mrk_bills/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /mrk_cash/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /mrk_staff/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_karya/{docId} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_clients_meta/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_fcm_tokens/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_rituals/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_checkins/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_gem_bids/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /vbe_call_tracker/{id} {
      allow read, write, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
