rules_version = '2';

// VBE Order Tracker — Firebase Storage Security Rules
// Firebase Console > Storage > Rules में paste करें

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Order photos ────────────────────────────────────────
    // सिर्फ supplier (Vikram) upload और delete कर सकते हैं
    // Customer tracking link से photo URL सीधे accessible रहेगी
    match /vbe_photos/{orderId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == "tjkS5tg2vMflpndGHSQRjFYgRv03"
                   && request.resource.size < 5 * 1024 * 1024  // max 5MB
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == "tjkS5tg2vMflpndGHSQRjFYgRv03";
    }

    // ─── Default: बाकी सब बंद ────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
