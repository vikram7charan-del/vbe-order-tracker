rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSupplier() {
      return request.auth != null
          && (request.auth.uid == "FqJeXbb3YJfSER09jtXLosCSpVy2"
           || request.auth.uid == "tjkS5tg2vMflpndGHSQRjFYgRv03"
           || request.auth.uid == "0CXFV9vDMSW7LBi0mLS9bW480mh1"
           || request.auth.uid == "CrWrobyeWHY1ZLrLwKcncW0U9K03"
           || request.auth.uid == "gdn0jahlzGOuWKaOyxsTht07mus2"
           || request.auth.uid == "pFslWWEvLiRjr7YFq51TqwfOpFp2"
           || request.auth.uid == "xY7dwh799LZrRIY7dK2CHVc5H262");
    }

    // Order photos — केवल supplier पढ़ और upload कर सकते हैं
    match /vbe_photos/{orderId}/{fileName} {
      allow read:   if isSupplier();
      allow write:  if isSupplier()
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isSupplier();
    }

    // खर्चा ट्रैकर bill photos — सिर्फ authenticated users, max 2MB, सिर्फ images
    // (role check Firestore rules में है; यहां auth + size + type enforce होता है)
    match /kharcha_bills/{fileName} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if isSupplier();
    }

    // बाकी सब बंद
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
